# Telegram
BOT_TOKEN=your_bot_token_here
CHANNEL_ID=@your_channel

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-large-latest
MISTRAL_FALLBACK_MODEL=mistral-small-latest

# Optional: football-data.org token for live scores
FOOTBALL_DATA_TOKEN=your_football_data_token

# Optional: Unsplash access key for real photos
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Run mode (news, live, digest_daily, digest_weekly, digest_monthly, facts, standings, analytics)
RUN_MODE=news

# Log level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
