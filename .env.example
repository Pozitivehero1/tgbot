# Copy this file to .env for local development
# NEVER commit .env to git

# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHANNEL_ID=@your_football_channel
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest

# ── Optional overrides (defaults shown) ──────────────────────────────────────
MISTRAL_FALLBACK_MODEL=mistral-small-latest
MISTRAL_TIMEOUT=120.0
MISTRAL_MAX_RETRIES=3
MISTRAL_RATE_LIMIT_RPM=30
MISTRAL_CACHE_TTL_SECONDS=3600

DATABASE_PATH=data/football_bot.db
DATA_DIR=data
IMAGES_DIR=data/images

RUN_MODE=news
MAX_PUBLICATIONS_PER_RUN=5
MIN_RELIABILITY_SCORE=0.6
PUBLICATION_DELAY_SECONDS=3.0

MAX_NEWS_AGE_HOURS=24
DEDUPLICATION_THRESHOLD=0.85

LOG_LEVEL=INFO
LOG_FORMAT=console

ANALYTICS_WINDOW_DAYS=30
ENABLE_SELF_LEARNING=true
